{
  "expo": {
    "name": "Ágora Mujeres",
    "slug": "agora-mujeres",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agora-mujeres",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "extra": {
      "EXPO_PUBLIC_BACKEND_URL": "http://localhost:8000",
      "EXPO_PUBLIC_STRIPE_KEY": "pk_live_51SRw7PL07UaiQy6MZzVJ6DHIRrZYNUvqRaoyLkkDi3LBXl5I6qUsN2Ky4Kqry0eOq1y0mS1mzYIqFIVlPFGE00pUYNlVzO"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Access location for weather updates",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Access location for weather updates"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDFBF9"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/agora-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FDFBF9"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Access location for weather updates"
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "tsconfigPaths": false
    }
  }
}
