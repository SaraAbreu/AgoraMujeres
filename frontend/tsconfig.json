{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "es2020",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "react",
      "react-native",
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".expo"
  ]
}
